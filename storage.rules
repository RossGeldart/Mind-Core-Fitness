rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /core/{allPaths=**} {
      allow read: if request.auth != null;
    }
    match /exercises/{allPaths=**} {
      allow read: if request.auth != null;
    }
    // Profile photos - clients can read/write their own, admin can read all
    match /profilePhotos/{clientId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Post images - authenticated users can upload to their own folder
    match /postImages/{clientId}/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Progress photos - metric body photos (path: progressPhotos/{clientId}/{period}/{imageId}.jpg)
    match /progressPhotos/{clientId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Comment images - attached to post comments
    match /comment-images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
