rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos - authenticated users can read all, write own
    match /profilePhotos/{clientId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Progress photos - authenticated users can read/write own
    match /progressPhotos/{clientId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Post images - authenticated users can read all, write own
    match /postImages/{clientId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Comment images - authenticated users can read/write
    match /comment-images/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
