{
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/login/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/blog/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:css|js))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:webp|avif|png|jpg|jpeg|svg|ico|woff2|woff))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/login",
      "destination": "/login/index.html"
    },
    {
      "source": "/login/",
      "destination": "/login/index.html"
    },
    {
      "source": "/login/dashboard",
      "destination": "/login/index.html"
    },
    {
      "source": "/login/calendar",
      "destination": "/login/index.html"
    },
    {
      "source": "/login/clients",
      "destination": "/login/index.html"
    },
    {
      "source": "/login/add-client",
      "destination": "/login/index.html"
    },
    {
      "source": "/login/upgrade",
      "destination": "/login/index.html"
    },
    {
      "source": "/login/signup",
      "destination": "/login/index.html"
    },
    {
      "source": "/login/:path*",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ],
      "destination": "/login/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/admin",
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/quick",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/core-buddy",
      "destination": "/",
      "permanent": false
    }
  ]
}
